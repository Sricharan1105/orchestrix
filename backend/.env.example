# Orchestrix Configuration Template
# Copy this file to '.env' and modify settings for production/local deployment.

# Database connection details (Defaults to PostgreSQL)
DATABASE_URL=postgresql://orchestrix:orchestrix_pass@localhost:5432/orchestrix

# Optional SQLite development fallback (uncomment to override)
# DATABASE_URL=sqlite:///./orchestrix.db

# Security settings (Ensure to change this to a secure random hash in production)
JWT_SECRET=replace-with-a-secure-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Worker recovery and heartbeat timeout constraints
WORKER_HEARTBEAT_TIMEOUT_SECONDS=15

# Allowed CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173

# Auto-seed mock data on startup (true/false)
SEED_DEMO_DATA=false

